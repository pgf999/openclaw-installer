# OpenClaw Configuration Template
# Copy this file to ~/.openclaw/config.env and fill in your values

# ===================
# API Keys
# ===================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# ===================
# OpenClaw Settings
# ===================
OPENCLAW_HOME=$HOME/.openclaw
OPENCLAW_WORKSPACE=$HOME/.openclaw/workspace
OPENCLAW_LOG_LEVEL=info
OPENCLAW_LOG_FILE=$HOME/.openclaw/logs/openclaw.log

# ===================
# Skills Configuration
# ===================
CLAWSEC_ENABLED=true
CLAWSEC_AUTO_SCAN=false

# ===================
# Network Settings
# ===================
# Uncomment if you need proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# ===================
# Advanced Settings
# ===================
OPENCLAW_MAX_WORKERS=4
OPENCLAW_TIMEOUT=300
